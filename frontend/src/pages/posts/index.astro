---
import { directus } from '../../lib/directus';
import { readItems } from '@directus/sdk';

const posts = await directus.request(
  readItems('posts', {
    filter: {
      status: {
        _eq: 'published'
      }
    },
    fields: ['id', 'title', 'slug', 'excerpt']
  })
);
---

<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <title>Artikel</title>
  </head>
  <body>
    <h1>Artikel</h1>

    <ul>
      {posts.map((item) => (
        <li>
          <a href={`/posts/${item.slug}`}>
            {item.title}
          </a>
          {item.excerpt && <div set:html={item.excerpt} />}
        </li>
      ))}
    </ul>
  </body>
</html>