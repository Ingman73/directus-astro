---
import Layout from '../../layouts/Layout.astro';
import { directus } from '../../lib/directus';
import { DIRECTUS_URL } from '../../lib/config';
import { readItems } from '@directus/sdk';

export async function getStaticPaths() {
  const posts = await directus.request(
    readItems('posts', {
      filter: {
        status: {
          _eq: 'published'
        }
      },
      fields: ['slug']
    })
  );

  return posts.map((item) => ({
    params: {
      slug: item.slug
    }
  }));
}

const { slug } = Astro.params;

const posts = await directus.request(
  readItems('posts', {
    filter: {
      slug: {
        _eq: slug
      },
      status: {
        _eq: 'published'
      }
    },
    fields: ['id', 'title', 'slug', 'excerpt', 'content', 'featured_image'],
    limit: 1
  })
);

const item = posts[0];

if (!item) {
  return Astro.redirect('/posts');
}
---

<Layout title={item.title}>
  <main>
    <article class="font-white p-vw-8 text content">
      <p>
        <a href="/posts">← Zurück zu allen Artikeln</a>
      </p>

      <h1>{item.title}</h1>

      {item.featured_image && (
        <img
          src={`${DIRECTUS_URL}/assets/${item.featured_image}?width=900&height=500&fit=cover`}
          alt={item.title}
          width="900"
          height="500"
        />
      )}

      {item.excerpt && <div set:html={item.excerpt} />}
      {item.content && <div set:html={item.content} />}
    </article>
  </main>
</Layout>