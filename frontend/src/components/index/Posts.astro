---
import { directus } from '../../lib/directus';
import { readItems } from '@directus/sdk';
import { DIRECTUS_URL } from '../../lib/config';

const posts = await directus.request(
  readItems('posts', {
    filter: {
      status: {
        _eq: 'published'
      }
    },
    fields: ['id', 'title', 'slug', 'excerpt', 'featured_image']
  })
);
---

<section class="font-white p-vw-8 text content">
  <h1>Artikel</h1>
  <ul>
    {posts.map((item) => (
      <li>
        <a href={`/posts/${item.slug}`}>
          {item.title}
        </a>
        {item.excerpt && <div set:html={item.excerpt} />}
        {item.featured_image && (
          <img
            src={`${DIRECTUS_URL}/assets/${item.featured_image}?width=600&height=200&fit=cover`}
            alt={item.title}
          />
        )}
      </li>
    ))}
  </ul>
</section>