---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Testseite',
  description = 'Website mit Directus und Astro',
} = Astro.props;
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="description" content={description} />
<meta name="generator" content={Astro.generator} />

<title>{title}</title>